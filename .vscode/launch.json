{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Pytest (Current File)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-s", "${file}"],
            "console": "integratedTerminal"
        },
        {
            "name": "Attach to LangGraph",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "0.0.0.0",
                "port": 5678
            },
        }
    ]
}